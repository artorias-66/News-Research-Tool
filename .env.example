# ─── LLM Provider Keys (provide one or both) ───
GROQ_API_KEY=
OPENAI_API_KEY=sk-your-openai-api-key-here
GOOGLE_API_KEY=your-google-gemini-api-key-here

# ─── API Configuration ───
# API_SECRET_KEY=your-api-secret-key      # Optional: API key auth for FastAPI
# RATE_LIMIT_MAX_TOKENS=20                 # Max burst requests per client
# RATE_LIMIT_REFILL_RATE=2.0               # Tokens refilled per second

# ─── Cache Configuration ───
# CACHE_MAX_SIZE=128                       # Max cached query results
# CACHE_TTL_SECONDS=3600                   # Cache entry lifetime (1 hour)
